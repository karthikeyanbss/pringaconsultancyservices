{
  "compileOnSave": false,
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Node",
    "experimentalDecorators": true,
    "emitDecoratorMetadata": true,
    "importHelpers": true,
    "noImplicitAny": false,
    "skipLibCheck": true,
    "strict": true,
    "lib": ["ES2020", "DOM"]
  },
  "angularCompilerOptions": {
    "enableIvy": true
  }
}
